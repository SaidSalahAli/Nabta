{
  "name": "nabta/educational-platform-api",
  "description": "Professional PHP Backend API for Nabta Educational Platform",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Nabta Development Team",
      "email": "dev@nabta.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "vlucas/phpdotenv": "^5.5",
    "firebase/php-jwt": "^7.0",
    "monolog/monolog": "^3.5",
    "respect/validation": "^2.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.48"
  },
  "autoload": {
    "psr-4": {
      "Nabta\\": "app/",
      "Nabta\\Config\\": "config/",
      "Nabta\\Routes\\": "routes/",
      "Nabta\\Database\\": "database/"
    },
    "files": [
      "app/Helpers/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Nabta\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "serve": "php -S localhost:8000 public/index.php",
    "migrate": "php bin/migrate",
    "seed": "php bin/seed",
    "test": "phpunit",
    "lint": "php-cs-fixer fix",
    "analyze": "phpstan analyse app/"
  }
}
