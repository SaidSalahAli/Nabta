    {
      "name": "Contact & Newsletter",
      "item": [
        {
          "name": "Send Contact Message",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/contact",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "contact"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+966501234567\",\n  \"subject\": \"Inquiry\",\n  \"message\": \"I have a question about your platform\"\n}"
            }
          }
        },
        {
          "name": "Subscribe to Newsletter",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/subscribe",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "subscribe"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"name\": \"User Name\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Episodes",
      "item": [
        {
          "name": "Create Episode",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/episodes",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "episodes"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 1,\n  \"title_ar\": \"درس الحروف\",\n  \"title_en\": \"Alphabet Lesson\",\n  \"youtube_url\": \"https://www.youtube.com/watch?v=dQw4w9WgXcQ\",\n  \"is_published\": true\n}"
            }
          }
        },
        {
          "name": "Update Episode",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/episodes/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "episodes", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title_ar\": \"درس الحروف المحدثة\",\n  \"is_featured\": true\n}"
            }
          }
        },
        {
          "name": "Delete Episode",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/episodes/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "episodes", "1"]
            }
          }
        }
      ]
    },
