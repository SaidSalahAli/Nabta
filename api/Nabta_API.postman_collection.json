        {
          "name": "Get Categories by Type",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/categories/episodes",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories", "episodes"]
            }
          }
        }
      ]
    },
