{
  "info": {
    "name": "Nabta Educational Platform API",
    "description": "Complete API collection for Nabta Educational Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/health",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "health"]
        }
      }
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed\",\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Episodes",
      "item": [
        {
          "name": "List Episodes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/episodes?page=1&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "episodes"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Featured Episodes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/episodes/featured?limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "episodes", "featured"],
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        },
        {
          "name": "Search Episodes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/episodes/search?q=english&page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "episodes", "search"],
              "query": [
                { "key": "q", "value": "english" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Get Episode by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/episodes/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "episodes", "1"]
            }
          }
        }
      ]
    },
